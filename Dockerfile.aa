FROM node:20-alpine AS deps
WORKDIR /usr/src/app
COPY ./dist/apps/aa/package.json ./
RUN npm install -g pnpm && \
    pnpm install --allow-build=@prisma/client,prisma && \
    pnpm store prune

FROM node:20-alpine AS builder
WORKDIR /usr/src/app
COPY ./dist/apps/aa/ ./
COPY ./prisma ./prisma
COPY --from=deps /usr/src/app/node_modules ./node_modules
RUN ./node_modules/.bin/prisma generate
CMD [ "node", "main.js" ]
